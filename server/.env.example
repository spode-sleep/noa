# === Server ===
PORT=3001
DATA_PATH=../data

# === Content Libraries (comma-separated for multiple folders, supports USB/external drives) ===
MUSIC_LIBRARY_PATH=/home/user/Music,/media/user/USB_DRIVE/Music
FICTION_LIBRARY_PATH=/home/user/Books,/media/user/USB_DRIVE/Books
REFERENCE_LIBRARY_PATH=/home/user/Reference,/media/user/USB_DRIVE/ZIM

# === Kiwix (ZIM reference viewer) ===
KIWIX_PORT=9454
KIWIX_SERVE_PATH=/usr/bin/kiwix-serve

# === TTS (Piper) ===
TTS_MODEL_PATH=/home/user/models/piper
TTS_DEFAULT_VOICE=ru_RU-medium

# === AI / LLM (Ollama or OpenAI-compatible) ===
LLM_API_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b
LLM_API_TYPE=auto

# === RAG (vector search over reference library) ===
EMBEDDING_MODEL=nomic-embed-text
MAX_RAG_CHUNKS=100000

# === ChromaDB (vector database for RAG) ===
CHROMA_PORT=8000
CHROMA_DATA_PATH=./chroma_data
